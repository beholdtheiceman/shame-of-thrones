# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
# unanchored so this also covers node_modules in apps/*/ and packages/*/
# (npm workspaces hoists most deps to the root, but per-workspace
# node_modules can still appear)
node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
coverage

# next.js
# unanchored so this also covers apps/web/.next, apps/web/out, etc.
.next/
out/

# production
build/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env
.env*.local
.env.test

# vercel
.vercel

# minted beta invite codes (operational — never commit)
invites-*.txt

# typescript
*.tsbuildinfo
next-env.d.ts
.env*
